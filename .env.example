# ============================================================
# SKM Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# Google Sheets
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/[THIS_ID]/edit
GOOGLE_SHEETS_ID=

# Service Account email from Google Cloud Console credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from Service Account JSON credentials
# Wrap with double quotes, use \n for newlines
GOOGLE_PRIVATE_KEY=""

# Google OAuth (Client ID & Secret from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
# Full URL of your app (e.g. http://localhost:3000 for dev, https://your-domain.com for prod)
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# App Config
NEXT_PUBLIC_APP_NAME=SKM
NEXT_PUBLIC_APP_VERSION=2.1

# Auth
# Generate with: openssl rand -hex 32
AUTH_SECRET=
# Generate with: openssl rand -hex 16
PIN_SALT=

# Fonnte WhatsApp API
# API token from fonnte.com dashboard
FONNTE_API_TOKEN=
